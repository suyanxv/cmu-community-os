# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/events
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/events

# Database (Neon.tech)
DATABASE_URL=postgresql://user:password@host.neon.tech/quorum?sslmode=require

# Anthropic (content generation, bulk imports, template parsing)
ANTHROPIC_API_KEY=sk-ant-...

# App URL (used for reminder email links, QR codes, public share URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Optional: Email broadcasts + daily reminder emails ──
# Without these, email broadcasts and reminder emails skip silently
# (rest of the app works fine). Sign up at https://resend.com/signup.
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=hello@mail.example.org
RESEND_FROM_NAME=Your Org Name

# ── Optional: Vercel Cron (daily reminder emails at 14:00 UTC) ──
# Any long random string. Vercel Cron passes this as
# `Authorization: Bearer <CRON_SECRET>` when it calls /api/cron/reminders.
# Generate with: openssl rand -hex 32
CRON_SECRET=
